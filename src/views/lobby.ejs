        </button>
      </div>
    </div>
  </div>
</div>

<!-- Modal for Moderators-->
<div id="modModal" class="modal fade" role="dialog">
  <div class="modal-dialog">
    <!-- Modal content-->
    <div class="modal-content">
      <div class="modal-header">
        <button type="button" class="close" data-dismiss="modal">
          &times;
        </button>
        <h2 class="modal-title" style="color: red; font-weight: 700">
          Ban menu
        </h2>
      </div>

      <div style="width: 75%; margin: auto">
        <br />
        <form action="/mod/ban" method="POST" id="modactionform">
          <div class="form-group">
            <label for="banPlayerUsername">Username of player to ban: </label>
            <input
              name="banPlayerUsername"
              type="text"
              class="form-control"
              id="banPlayerUsername"
              placeholder="Username"
              required
            />
          </div>

          <div class="form-group">
            <h3 style="font-weight: 700; display: inline">Type of ban:</h3>
            <h6 style="display: inline">
              Note: If IP ban is selected, all IPs the user has ever logged onto
              will be banned for the specified duration.
            </h6>
            <br />
            <label
              ><input type="checkbox" name="userBanCheckbox" /> User ban</label
            >
            <!--! fill in the id/data-->
            <br />
            <label
              ><input type="checkbox" name="IPBanCheckbox" /> Full IP ban</label
            >
            <br />
            <label
              ><input type="checkbox" name="SingleIPBanCheckbox" /> Last IP ban
              (Single)</label
            >
          </div>

          <div class="form-group">
            <label for="reason">Reason: </label>
            <br />
            <select
              name="reason"
              class="form-control"
              id="typeofmodaction"
              required
            >
              <option value="">Please select an option</option>
              <option value="abusive">Abusive</option>
              <option value="griefing">Intentional throwing/griefing</option>
              <option value="afk">Inactivity (AFK)</option>
              <option value="spam">Spam</option>
              <option value="cheating">
                Cheating (multiaccounting or talking outside of game)
              </option>
              <option value="other">Other</option>
            </select>
          </div>

          <div class="form-group">
            <h3 style="font-weight: 700; display: inline">Duration:</h3>
            <h6 style="display: inline">
              Note: If perma ban is selected, the number given is not used.
            </h6>
            <div class="input-group">
              <input
                type="text"
                class=""
                id="duration"
                name="duration"
                placeholder="<number>"
                required
              />
              <select
                name="duration_units"
                class=""
                id="durationofmodaction"
                required
              >
                <option value="">None</option>
                <option value="hrs">hrs</option>
                <option value="days">days</option>
                <option value="months">months</option>
                <option value="years">years</option>
                <option value="permaban">permaban</option>
              </select>
            </div>
          </div>

          <div class="form-group">
            <label for="descriptionByMod"
              >Description:
              <h6 style="display: inline">
                The user being banned will see this message. This message will
                also appear in the moderator logs.
              </h6></label
            >
            <br />
            <textarea
              name="descriptionByMod"
              class="form-control"
              style="width: 100%"
              id="descriptionByMod"
              required
            ></textarea>
          </div>

          <!--<input type="submit" value="Slam the hammer of judgement!" class="btn btn-danger" id="modActionCloseButton">-->
          <button
            id="modActionCloseButton"
            type="button"
            class="btn btn-danger"
          >
            Submit
          </button>
          <br />
          <br />
        </form>
      </div>

      <div class="modal-footer">
        <button type="button" class="btn btn-default" data-dismiss="modal">
          Close
        </button>
      </div>
    </div>
  </div>
</div>

