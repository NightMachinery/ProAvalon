<!-- Modal for game options-->
<div id="roleOptionsModal" class="modal fade" role="dialog">
  <div class="modal-dialog">
    <!-- Modal content-->
    <div class="modal-content">
      <div class="modal-header">
        <button type="button" class="close" data-dismiss="modal">
          &times;
        </button>
        <h2 class="modal-title">Game options!</h2>
      </div>
      <div class="modal-body">
        <h4>Select the roles/items you would like in the game.</h4>
        <h6>Default roles have been pre-selected.</h6>

        <label>Game Mode:</label>
        <select class="gameModeSelect" name="gameMode">
          <!-- The usual values look like the below. This part is inserted dynamically in lobby.js -->
          <!-- <option value="avalon">Avalon</option> -->
          <!-- <option value="hunter">Hunter</option> -->
          <!-- <option value="original">Original</option> -->
        </select>
        <br />

        <div class="avalonSelectCheck" style="display: block">
          <label>Type:</label>
          <select class="rankedSelect" name="ranked">
            <option value="ranked">Ranked (Beta)</option>
            <option value="unranked">Unranked</option>
          </select>
        </div>

        <label>Default Timeout: min: <input type="text" id="startGameOptionsDefaultPhaseTimeoutMin" style="width: 3em;" value="0" min="0" max="99"></label>
        <label>sec: <input type="text" id="startGameOptionsDefaultPhaseTimeoutSec" style="width: 3em;" value="0" min="0" max="60"></label>
        <br>
        <label>Critical Mission Timeout: min:  <input type="number" id="startGameOptionsCritMissionTimeoutMin" style="width: 3em;" value="0" min="0" max="99"></label>
        <label>sec:  <input type="text" id="startGameOptionsCritMissionTimeoutSec" style="width: 3em;" value="0" min="0" max="60"></label>
        <br>
        <label>Assassination Timeout: min:  <input type="number" id="startGameOptionsAssassinationPhaseTimeoutMin" style="width: 3em;" value="0" min="0" max="99"></label>
        <label>sec:  <input type="text" id="startGameOptionsAssassinationPhaseTimeoutSec" style="width: 3em;" value="0" min="0" max="60"></label>
        <br>
        <label>Anonymous mode:</label>
        <input type="checkbox" name="startGameOptionsAnonymousMode" id="startGameOptionsAnonymousMode"/>
        <br>
        <label>Show exact evil roles to evil team:</label>
        <input
          type="checkbox"
          name="startGameOptionsRevealExactSpyRolesToSpies"
          id="startGameOptionsRevealExactSpyRolesToSpies"
        />

        <div class="row">
          <div
            class="btn-group-vertical col-sm-4 col-xs-12"
            data-toggle="buttons"
            id="rolesCardsButtonGroup"
          ></div>

          <div
            class="btn-group-vertical col-sm-8 col-xs-12"
            data-toggle="buttons"
            id="rolesCardsButtonGroupDescription"
          ></div>
        </div>

        <br />

        <label>Max number of players:</label>
        <select class="maxNumPlayers" name="maxNumPlayers">
          <option value="5">5</option>
          <option value="6">6</option>
          <option value="7">7</option>
          <option value="8">8</option>
          <option value="9">9</option>
          <option value="10" selected="selected">10</option>
        </select>

        <br />

        <label>Mute spectators for table:</label>
        <input type="checkbox" name="muteSpectators" class="muteSpectators" />
        <br />
        <label>Disable Vote History:</label>
        <input type="checkbox" name="disableVoteHistory" class="disableVoteHistory"/>
        <br />
        <label>Show room in main list:</label>
        <input type="checkbox" name="listedInLobby" class="listedInLobby" checked />
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-default" data-dismiss="modal">
          Close
        </button>
      </div>
    </div>
  </div>
</div>

<!-- Modal for bot controls -->
<div id="botControlModal" class="modal fade" role="dialog">
  <div class="modal-dialog">
    <div class="modal-content">
      <div class="modal-header">
        <button type="button" class="close" data-dismiss="modal">
          &times;
        </button>
        <h2 class="modal-title">Bot controls</h2>
      </div>
      <div class="modal-body">
        <p>
          Host-only controls for adding standalone SimpleBots before game start
          and switching live seats between SimpleBot, the original player, and
          connected spectators during a running game.
        </p>

        <div class="form-group">
          <label for="botAddCount">Add standalone SimpleBots</label>
          <div style="display: flex; gap: 0.75rem; align-items: center;">
            <input
              id="botAddCount"
              type="number"
              min="1"
              max="10"
              value="1"
              class="form-control"
              style="max-width: 7rem;"
            />
            <button type="button" class="btn btn-primary" id="botAddButton">
              Add bot
            </button>
            <button type="button" class="btn btn-danger" id="botRemoveAllButton">
              Remove all standalone bots
            </button>
          </div>
        </div>

        <hr />

        <h4>Seats</h4>
        <div id="botControlSeatList"></div>

        <hr />

        <p class="text-muted">
          Slash commands: <code>/addbot</code>, <code>/rembot</code>,
          <code>/switchseat</code>, <code>/takebot</code>,
          <code>/restorehuman</code>
        </p>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-default" data-dismiss="modal">
          Close
        </button>
      </div>
    </div>
  </div>
</div>

<!-- Modal for kicking players-->
<div id="kickModal" class="modal fade" role="dialog">
  <div class="modal-dialog">
