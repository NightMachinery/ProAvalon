<style>
  .avatarImgInRoom {
    width: 128px;
    height: 128px;
  }
</style>

<!-- <div class="container lobby-container"> -->
<div class="container lobby-container">
  <div class="lobby-mobile-tabs" role="tablist" aria-label="Lobby sections">
    <button
      type="button"
      class="lobby-mobile-tab"
      data-target="col2"
      aria-controls="col2"
      aria-selected="true"
    >
      Games &amp; Players
    </button>
    <button
      type="button"
      class="lobby-mobile-tab"
      data-target="col1"
      aria-controls="col1"
      aria-selected="false"
    >
      All Chat
    </button>
  </div>

  <div class="row lobby-main-row">
    <div class="col-xs-12 col-sm-9 lobby-mobile-panel" id="col1">
      <section class="lobby-panel-shell lobby-panel-chat">
        <div class="lobby-section-header">
          <h2 class="section-title" id="all-chat-lobby-text">All Chat</h2>

          <div react-entrypoint id="reportDiv" class="lobby-section-report">
            <%-reportsReact%>
          </div>
        </div>

        <div class="chat-window" id="all-chat-lobby">
          <ol class="chat-list all-chat-list" id="all-chat-lobby-list"></ol>
        </div>
        <p id="all-chat-lobby-bar" class="hidden chat-bar"></p>

        <input type="text" class="chat-message-input all-chat-message-input" />
      </section>
    </div>

    <div class="col-xs-12 col-sm-3 lobby-mobile-panel active" id="col2">
      <section class="lobby-panel-shell lobby-panel-games">
        <div class="lobby-section-header lobby-section-header--stacked">
          <div>
            <h2 class="section-title">Games</h2>
            <p class="section-subtitle">
              <span class="games-count">0</span> active rooms
            </p>
          </div>
          <a id="newRoom" class="btn btn-game btn-game-primary" href="#"
            >New Room</a
          >
        </div>

        <div react-entrypoint id="matchmakingDiv" class="lobby-matchmaking-shell">
          <%-matchmakingReact%>
        </div>

        <table
          id="current-games-table"
          class="table table-bordered table-striped lobby-table"
        >
          <tbody></tbody>
        </table>

        <div class="lobby-subsection-header">
          <h3 class="section-title section-title--compact">Online players</h3>
          <span class="section-meta player-count"></span>
        </div>

        <table
          id="current-players-table"
          class="table table-bordered table-striped lobby-table"
        >
          <tbody></tbody>
        </table>
      </section>
    </div>
  </div>
</div>

<div class="game-container inactive-window">
  <!-- container -->
  <div id="div1Resize">
    <div class="room-container">
      <div class="roomInfoBar roomBar">
        <div class="roomInfoPrimary">
          <button
            id="claimButton"
            class="disabled btn btn-game btn-game-primary"
          >
            Claim
          </button>
        </div>

        <div class="roomInfoMissionTrack">
          <div id="missionsBox" class="invisible">
            <div class="row missionTrackRow">
              <div class="missionBox" id="missionBox0"></div>
              <div class="missionBox" id="missionBox1"></div>
              <div class="missionBox" id="missionBox2"></div>
              <div class="missionBox" id="missionBox3"></div>
              <div class="missionBox" id="missionBox4"></div>
            </div>

            <div class="row pickTrackRow">
              <div class="pickBox" id="pickBox0"></div>
              <div class="pickBox" id="pickBox1"></div>
              <div class="pickBox" id="pickBox2"></div>
              <div class="pickBox" id="pickBox3"></div>
              <div class="pickBox" id="pickBox4"></div>
            </div>
          </div>
        </div>

        <div class="roomInfoBadges">
          <div class="gameInfoMaxPlayers badge badge-game">8/9</div>
          <div class="gameTimer badge badge-game">--:--</div>
        </div>
      </div>

      <div class="roomBoard">
        <div id="mainRoomBox" class="">
          <p></p>
        </div>

        <span class="gun gunBefore"
          ><img class="gunImg" src="pictures/gun.png"
        /></span>
        <span class="gun gunBefore"
          ><img class="gunImg" src="pictures/gun.png"
        /></span>
        <span class="gun gunBefore"
          ><img class="gunImg" src="pictures/gun.png"
        /></span>
        <span class="gun gunBefore"
          ><img class="gunImg" src="pictures/gun.png"
        /></span>
        <span class="gun gunBefore"
          ><img class="gunImg" src="pictures/gun.png"
        /></span>
      </div>

      <div class="roomHeaderButtons roomBar">
        <button id="backButton" class="btn btn-game btn-game-secondary">
          Back
        </button>
        <button
          id="botControlsButton"
          class="btn btn-game btn-game-secondary hidden"
          type="button"
          data-toggle="modal"
          data-target="#botControlModal"
        >
          Bots
        </button>
        <button id="copyRoomLinkButton" class="btn btn-game btn-game-secondary">
          Copy link
        </button>
        <button id="restartRoomButton" class="btn btn-game btn-game-secondary hidden">
          Restart lobby
        </button>
      </div>
    </div>
  </div>
