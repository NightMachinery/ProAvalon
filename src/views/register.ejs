<%- include('partials/header') %>

<style type="text/css">
  .signup-form {
    max-width: 420px;
    margin: 20px auto;
  }

  .signup-form form {
    margin-bottom: 15px;
    background: #f7f7f7;
    box-shadow: 0 2px 2px rgba(0, 0, 0, 0.3);
    border: #b5b5b5 2px solid;
    padding: 30px;
  }
</style>

<div class="container">
  <div class="signup-form">
    <form action="/" method="POST" id="registerForm">
      <input type="hidden" name="next" value="<%= nextPath || '' %>">
      <h2 class="text-center">Legacy sign up</h2>

      <% if (isSelfHost) { %>
      <p>
        Quick start is available on <a href="/<%= nextPath ? '?next=' + encodeURIComponent(nextPath) : '' %>">the front page</a>. This legacy form is only needed if you explicitly want a manual username/password signup.
      </p>
      <% } %>

      <div class="form-group">
        <label class="alignLeft pull-left" for="username">Username</label>
        <input type="text" id="username" name="username" class="form-control" placeholder="Username" required />
      </div>

      <div class="form-group">
        <label class="alignLeft pull-left" for="inputPassword">Password</label>
        <input type="password" name="password" class="form-control" placeholder="Password" required id="inputPassword" minlength="4" />
      </div>

      <div class="form-group">
        <label class="alignLeft pull-left" for="confirmPassword">Confirm password</label>
        <input type="password" name="confirmPassword" class="form-control" placeholder="Confirm password" required id="confirmPassword" minlength="4" />
      </div>

      <div class="form-group">
        <label class="alignLeft pull-left" for="emailAddress">Email address</label>
        <input
          type="email"
          id="emailAddress"
          name="emailAddress"
          class="form-control"
          placeholder="Email Address"
          <%= isSelfHost ? '' : 'required' %>
        />
      </div>

      <% if (isSelfHost) { %>
      <p>Email is optional in self-host mode. Email verification and password reset by email are disabled there.</p>
      <% } else { %>
      <p>Email is used for verification and password recovery.</p>
      <% } %>

      <p>
        Note: only alphanumerical characters are allowed in the username (a-z, A-Z and 0-9).
      </p>

      <button type="submit" class="btn btn-primary btn-block">Submit</button>
    </form>
  </div>
</div>

<script>
  $('#registerForm').on('submit', function (event) {
    const password = $('#inputPassword').val();
    const confirmPassword = $('#confirmPassword').val();

    if (password !== confirmPassword) {
      event.preventDefault();
      Swal.fire({
        title: 'Passwords do not match.',
        type: 'error',
      });
    }
  });
</script>

<%- include('partials/footer') %>
